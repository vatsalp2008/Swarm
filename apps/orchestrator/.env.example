# Postgres direct URL (LISTEN/NOTIFY requires non-pooled connection).
DATABASE_URL=postgres://postgres:PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Gemini API key — free tier from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# LangSmith (optional in Phase 0; required from Week 3 for Bee tracing)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=swarm-dev

# Listen channel name (must match the Next.js route handler in apps/web)
LISTEN_CHANNEL=swarm_tasks

# Health check port
PORT=8080

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info
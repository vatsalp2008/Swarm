# Copy to .env.local and fill in. .env.local is git-ignored.

# Supabase project URL and anon key — from Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Service-role key — server-only. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Postgres direct URL (for Drizzle migrations and audit verification)
DATABASE_URL=postgres://postgres:PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Optional: pooled URL for app runtime queries (Supavisor; port 6543)
# DATABASE_POOL_URL=postgres://postgres.YOUR_PROJECT:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres